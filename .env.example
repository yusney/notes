# ============================================================
# Notes - Gestor de Conocimiento Personal
# Environment Variables Example
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets!
# ============================================================

# ── PostgreSQL Database ──────────────────────────────────────
POSTGRES_DB=notes_db
POSTGRES_USER=notes_user
POSTGRES_PASSWORD=change_me_strong_password

# ── ASP.NET Core ─────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ── Connection String (used by API in docker-compose) ───────
# This is assembled from POSTGRES_* vars above by docker-compose
# For standalone runs, set it directly:
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=notes_db;Username=notes_user;Password=change_me

# ── JWT Authentication ───────────────────────────────────────
# Must be at least 32 characters long for HS256
Jwt__Secret=replace_with_a_long_random_secret_at_least_32_chars
Jwt__Issuer=notes-api
Jwt__Audience=notes-client

# ── API URL (used by Tauri desktop app) ──────────────────────
# Development: http://localhost:8080
# Production (VPS): https://api.your-domain.com
VITE_API_BASE_URL=http://localhost:8080
