{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notes",
  "version": "0.2.0",
  "identifier": "dev.donduque.notes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Notes - Gestor de Conocimiento",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Yusney Martínez Duque",
    "homepage": "https://donduque.dev/",
    "copyright": "© 2026 Yusney Martínez Duque",
    "linux": {
      "deb": {
        "maintainer": "Yusney Martínez Duque <yusney@donduque.dev>"
      }
    }
  }
}
